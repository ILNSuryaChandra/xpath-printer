{
  "manifest_version": 3,
  "name": "Project Snapshot",
  "version": "1.0.0",
  "description": "Bypass web-based print restrictions by selecting any DOM element and exporting it as a high-fidelity PDF — ignoring CSS print-protection rules.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Project Snapshot — Capture Any Element"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/html2canvas.min.js", "libs/jspdf.umd.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
